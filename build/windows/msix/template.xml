<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="markdownmd"
        Arguments=""
        InstallLocation="C:\Program Files\\MarkdownMD">
    </Installer>
    <PackageInformation
        PackageName="MarkdownMD"
        PackageDisplayName="MarkdownMD"
        PublisherName="CN="
        PublisherDisplayName=""
        Version="0.1.0.0"
        PackageDescription="A MarkdownMD application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.markdownmd.app"
                Description="A MarkdownMD application"
                DisplayName="MarkdownMD"
                ExecutableName="markdownmd"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>MarkdownMD</DisplayName>
            <PublisherDisplayName></PublisherDisplayName>
            <Description>A MarkdownMD application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="markdownmd.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
